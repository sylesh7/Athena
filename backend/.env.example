# ── Circle API (Phase 1 wallet setup) ──────────────────────────────────────
# Format: PREFIX:ID:SECRET — shown once when created at console.circle.com
CIRCLE_API_KEY=
# Generated + registered via @circle-fin/developer-controlled-wallets.
# Store the recovery file it produces somewhere safe — never commit it.
CIRCLE_ENTITY_SECRET=

# ── Wallet private keys ─────────────────────────────────────────────────────
# Populated by `npm run wallets:setup` into backend/.env.local (gitignored).
# Broker wallet calls commit()/reveal() on AthenaCommit and runs the stream loop.
BROKER_PK=
BROKER_WALLET_ADDRESS=

# Provider wallets receive x402 nanopayments for their endpoints.
PROVIDER1_PK=
PROVIDER1_WALLET_ADDRESS=
PROVIDER2_PK=
PROVIDER2_WALLET_ADDRESS=
PROVIDER3_PK=
PROVIDER3_WALLET_ADDRESS=

# ── Ports ────────────────────────────────────────────────────────────────────
PROVIDER1_PORT=3001
PROVIDER2_PORT=3002
PROVIDER3_PORT=3003
ENTRYPOINT_PORT=3000
MCP_MONITOR_URL=http://localhost:8000/mcp

# ── Client-facing bond default ──────────────────────────────────────────────
# 6-decimal atomic USDC units (matches AthenaCommit's bondAmount param) —
# 1_000_000 = 1.00 USDC. NOT a dollar figure.
DEFAULT_BOND_UNITS=1000000

# Calls per stream before the server-enforced cap (see MAX_CALLS_CAP in
# stream/entrypoint.ts) — keeps demo runs from hammering free-tier price APIs.
DEFAULT_MAX_CALLS=10
