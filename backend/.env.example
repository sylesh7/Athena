# ── Circle API (Phase 1 wallet setup) ──────────────────────────────────────
# Format: PREFIX:ID:SECRET — shown once when created at console.circle.com
CIRCLE_API_KEY=
# Generated + registered via @circle-fin/developer-controlled-wallets.
# Store the recovery file it produces somewhere safe — never commit it.
CIRCLE_ENTITY_SECRET=

# ── Wallet private keys ─────────────────────────────────────────────────────
# Populated by `npm run wallets:setup` into backend/.env.local (gitignored).
# Broker wallet calls commit()/reveal() on AthenaCommit and runs the stream loop.
BROKER_PK=
BROKER_WALLET_ADDRESS=

# Provider wallets receive x402 nanopayments for their endpoints.
PROVIDER1_PK=
PROVIDER1_WALLET_ADDRESS=
PROVIDER2_PK=
PROVIDER2_WALLET_ADDRESS=
PROVIDER3_PK=
PROVIDER3_WALLET_ADDRESS=

# ERC-8004 reputation feedback (README.md step 7) — a genuinely separate
# wallet, NOT the broker's or any provider's own key. ERC-8004's
# ReputationRegistry blocks an agent's owner from giving itself feedback
# (anti-self-dealing) — see contracts/src/interfaces/IERC8004.sol and
# lib/reputation.ts. If unset, streamLoop.ts logs a warning and skips
# feedback posting rather than failing the stream.
VALIDATOR_PK=

# ── Ports ────────────────────────────────────────────────────────────────────
PROVIDER1_PORT=3001
PROVIDER2_PORT=3002
PROVIDER3_PORT=3003
ENTRYPOINT_PORT=3000
MCP_MONITOR_URL=http://localhost:8000/mcp

# ── Client-facing bond default ──────────────────────────────────────────────
# 6-decimal atomic USDC units (matches AthenaCommit's bondAmount param) —
# 1_000_000 = 1.00 USDC. NOT a dollar figure.
DEFAULT_BOND_UNITS=1000000

# Calls per stream before the server-enforced cap (see MAX_CALLS_CAP in
# stream/entrypoint.ts) — keeps demo runs from hammering free-tier price APIs.
DEFAULT_MAX_CALLS=10

# ── Phase 4, stretch: CCTP cross-chain payout (Provider 3 -> Base Sepolia) ──
# Off by default — needs the broker wallet separately funded with Base
# Sepolia ETH (faucet.circle.com or a Base Sepolia faucet), and a completed
# stream can take up to 3 hours for Circle's Iris attestation. See
# cctp/crossChainPayout.ts.
ENABLE_CCTP_PAYOUT=false
# Optional override — defaults to the public https://sepolia.base.org
BASE_SEPOLIA_RPC=

# CoinGecko Demo API key (CG-... ) — lifts the free-tier 429 rate limit on provider
# data fetches. Get one free at https://www.coingecko.com/en/developers/dashboard
COINGECKO_API_KEY=
